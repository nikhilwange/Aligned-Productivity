# Server-side only — set in Vercel Project Settings → Environment Variables.
# Never use a VITE_ prefix for these; that would bundle them into the client.
GEMINI_API_KEY=your_gemini_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Client-side (safe to expose) — used by the browser to talk to Supabase directly.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
